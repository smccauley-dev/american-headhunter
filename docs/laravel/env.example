# ============================================================
# American Headhunter — Environment Configuration Reference
#
# This file documents every environment variable the platform
# reads. Copy .env.example to .env and fill in values.
#
# NEVER commit .env to version control.
# Production credentials come from Azure Key Vault.
# Dev credentials default to Docker Compose service names.
# ============================================================


# ────────────────────────────────────────────────────────────
# APP
# ────────────────────────────────────────────────────────────

# Human-readable app name — shown in emails, UI headers.
APP_NAME="American Headhunter"

# Environment. Values: local | staging | production
# Controls debug output, stack traces, log verbosity.
APP_ENV=local

# Laravel application key — used for encryption and CSRF.
# Generate with: php artisan key:generate
# Required. Never share this value.
APP_KEY=

# Enable/disable debug mode and detailed error pages.
# Set false in production — never expose stack traces to users.
APP_DEBUG=true

# Canonical base URL for the application.
# Used in generated URLs, email links, Vite asset paths.
APP_URL=http://localhost

# Host port that the app container listens on.
# Default 80. Change if port 80 is in use on your machine.
APP_PORT=80

# Laravel locale settings.
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance mode driver — file-based is fine for single-server.
APP_MAINTENANCE_DRIVER=file

# bcrypt cost for password hashing. 12 is a good default.
# Increase to slow down brute force. Decreasing below 10 is not recommended.
BCRYPT_ROUNDS=12


# ────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────

# Primary log channel. Options: single | daily | stack | stderr
# Use 'stderr' in Docker (logs go to docker logs / Azure Monitor).
LOG_CHANNEL=stack

# Which channels make up the 'stack' log channel.
LOG_STACK=single

# Suppress deprecation warnings in logs (they can be noisy).
LOG_DEPRECATIONS_CHANNEL=null

# Minimum log level. Values: debug | info | notice | warning | error | critical
LOG_LEVEL=debug


# ────────────────────────────────────────────────────────────
# DATABASE — SHARED SETTINGS
# ────────────────────────────────────────────────────────────

# Default connection key. Must be 'identity' — do not change.
# Every model and migration explicitly declares its own connection.
DB_CONNECTION=identity

# SSL mode for all PostgreSQL connections.
# Values: disable | allow | prefer | require | verify-ca | verify-full
# prefer = encrypted if server supports it (dev/staging).
# require = mandatory TLS (production).
DB_SSLMODE=prefer

# PostgreSQL root superuser password (used only by Docker init scripts).
# Not used by the application.
DB_ROOT_PASSWORD=secret

# Shared read-only user (used by property_read, wildlife_read, geospatial_read, analytics).
# This user has SELECT-only access. Provisioned by docker/postgres/init.sql.
DB_READONLY_USERNAME=ah_readonly
DB_READONLY_PASSWORD=secret

# Shared ETL user (used by analytics_etl and research connections).
# Owner of the ah_analytics and ah_research databases.
DB_ETL_USERNAME=ah_etl
DB_ETL_PASSWORD=secret


# ────────────────────────────────────────────────────────────
# DATABASE — 14 POSTGRESQL CONNECTIONS
#
# In Docker, all databases live on the 'postgres' service.
# In production, the host and credentials change per environment.
# The connection key in config/database.php matches the prefix here.
# ────────────────────────────────────────────────────────────

# DB 1 — Identity & Authentication
# Users, roles, MFA, trust scores, verifications, sessions.
DB_IDENTITY_HOST=postgres
DB_IDENTITY_PORT=5432
DB_IDENTITY_DATABASE=ah_identity
DB_IDENTITY_USERNAME=ah_app
DB_IDENTITY_PASSWORD=secret

# DB 2 — Property & Land
# Property listings, photos, pricing, availability.
# property_read uses DB_READONLY_USERNAME + optional separate host.
DB_PROPERTY_HOST=postgres
DB_PROPERTY_PORT=5432
DB_PROPERTY_DATABASE=ah_property
DB_PROPERTY_USERNAME=ah_app
DB_PROPERTY_PASSWORD=secret
# Read replica (leave blank to fall back to primary host):
DB_PROPERTY_READ_HOST=
DB_PROPERTY_READ_PORT=5432

# DB 3 — Lease & Contract
# Leases, applications, clubs, check-in logs, e-signature records.
DB_LEASE_HOST=postgres
DB_LEASE_PORT=5432
DB_LEASE_DATABASE=ah_lease
DB_LEASE_USERNAME=ah_app
DB_LEASE_PASSWORD=secret

# DB 4 — Billing & Payments
# Invoices, payments, subscriptions, Stripe data, payouts, 1099s.
# Never store raw card numbers — Stripe token IDs only.
DB_BILLING_HOST=postgres
DB_BILLING_PORT=5432
DB_BILLING_DATABASE=ah_billing
DB_BILLING_USERNAME=ah_app
DB_BILLING_PASSWORD=secret

# DB 5 — Wildlife & Field Operations
# Harvest logs, game sightings, trail cameras, quotas, seasons.
DB_WILDLIFE_HOST=postgres
DB_WILDLIFE_PORT=5432
DB_WILDLIFE_DATABASE=ah_wildlife
DB_WILDLIFE_USERNAME=ah_app
DB_WILDLIFE_PASSWORD=secret
# Read replica (leave blank to fall back to primary host):
DB_WILDLIFE_READ_HOST=
DB_WILDLIFE_READ_PORT=5432

# DB 6 — Commerce & Marketplace
# Auctions, bids, marketplace listings, outfitter packages, bookings.
DB_COMMERCE_HOST=postgres
DB_COMMERCE_PORT=5432
DB_COMMERCE_DATABASE=ah_commerce
DB_COMMERCE_USERNAME=ah_app
DB_COMMERCE_PASSWORD=secret

# DB 7 — Communications
# Message threads, notifications, support tickets, SOS events.
DB_COMMUNICATIONS_HOST=postgres
DB_COMMUNICATIONS_PORT=5432
DB_COMMUNICATIONS_DATABASE=ah_communications
DB_COMMUNICATIONS_USERNAME=ah_app
DB_COMMUNICATIONS_PASSWORD=secret

# DB 8 — Analytics (read-only for app — ETL writes via analytics_etl connection)
# ETL-populated metrics and reporting tables.
# The application never writes here — only ETL job classes use analytics_etl.
DB_ANALYTICS_HOST=postgres
DB_ANALYTICS_PORT=5432
DB_ANALYTICS_DATABASE=ah_analytics
# analytics connection uses DB_READONLY_USERNAME (defined above)
# analytics_etl connection uses DB_ETL_USERNAME (defined above)

# DB 9 — Audit & Compliance (append-only)
# Immutable audit log — INSERT only, 10-year retention.
DB_AUDIT_HOST=postgres
DB_AUDIT_PORT=5432
DB_AUDIT_DATABASE=ah_audit
DB_AUDIT_USERNAME=ah_app
DB_AUDIT_PASSWORD=secret

# DB 10 — Incidents & Safety
# Safety incidents, property damage claims, trespass reports, disputes.
DB_INCIDENTS_HOST=postgres
DB_INCIDENTS_PORT=5432
DB_INCIDENTS_DATABASE=ah_incidents
DB_INCIDENTS_USERNAME=ah_app
DB_INCIDENTS_PASSWORD=secret

# DB 11 — Documents & Media
# File metadata, e-sign requests, QR codes, video processing jobs, digital IDs.
DB_DOCUMENTS_HOST=postgres
DB_DOCUMENTS_PORT=5432
DB_DOCUMENTS_DATABASE=ah_documents
DB_DOCUMENTS_USERNAME=ah_app
DB_DOCUMENTS_PASSWORD=secret

# DB 12 — Platform Configuration
# Feature flags, tenant settings, membership plans, entitlements, promotions.
DB_PLATFORM_HOST=postgres
DB_PLATFORM_PORT=5432
DB_PLATFORM_DATABASE=ah_platform
DB_PLATFORM_USERNAME=ah_app
DB_PLATFORM_PASSWORD=secret

# DB 13 — Geospatial (PostGIS)
# Property boundaries, zones, stand locations, CWD polygons, harvest locations.
DB_GEOSPATIAL_HOST=postgres
DB_GEOSPATIAL_PORT=5432
DB_GEOSPATIAL_DATABASE=ah_geospatial
DB_GEOSPATIAL_USERNAME=ah_app
DB_GEOSPATIAL_PASSWORD=secret
# Read replica (leave blank to fall back to primary host):
DB_GEOSPATIAL_READ_HOST=
DB_GEOSPATIAL_READ_PORT=5432

# DB 14 — Research Dataset (ETL only — no application access)
# Air-gapped anonymized dataset. Application code never connects here.
# Only App\Jobs\Research\* classes use this connection via DB_ETL_USERNAME.
DB_RESEARCH_HOST=postgres
DB_RESEARCH_PORT=5432
DB_RESEARCH_DATABASE=ah_research
# Uses DB_ETL_USERNAME (defined above)


# ────────────────────────────────────────────────────────────
# VALKEY — 5 INDEPENDENT CLUSTERS
#
# Inside Docker, containers communicate on the internal network
# using service names and port 6379.
# Host machines access Valkey via ports 16379-16383 (see docker_compose.md).
#
# REDIS_CLIENT must be phpredis. Valkey is Redis-compatible.
# ────────────────────────────────────────────────────────────

REDIS_CLIENT=phpredis

# Cluster 1 — Sessions
# Stores Laravel session data, MFA state, magic link tokens.
# Persistence enabled (sessions survive restart).
# Failure forces re-authentication — does not affect billing or lease ops.
VALKEY_SESSIONS_HOST=valkey_sessions
VALKEY_SESSIONS_PORT=6379
VALKEY_SESSIONS_PASSWORD=null

# Cluster 2 — App Cache
# Property listings, lease summaries, feature flags, entitlements.
# TTLs range from 5 minutes (volatile) to 60 minutes (stable config).
# Used via Cache::store('valkey') throughout the service layer.
VALKEY_CACHE_HOST=valkey_cache
VALKEY_CACHE_PORT=6379
VALKEY_CACHE_PASSWORD=null

# Cluster 3 — Job Queue
# Laravel queue jobs (priority and default named queues).
# Persistence enabled — jobs survive container restart.
# Failure = jobs stop processing; re-enqueue on restart.
VALKEY_QUEUE_HOST=valkey_queue
VALKEY_QUEUE_PORT=6379
VALKEY_QUEUE_PASSWORD=null

# Cluster 4 — Auction State
# Live bid amounts, countdown timers, bid locks, reserve met flags.
# High-frequency writes during auction close windows.
# Used directly via Redis::connection('auction') — not the Cache facade.
VALKEY_AUCTION_HOST=valkey_auction
VALKEY_AUCTION_PORT=6379
VALKEY_AUCTION_PASSWORD=null

# Cluster 5 — Rate Limiting
# Per-user and per-IP API throttle counters (rolling time window).
# Used via Redis::connection('ratelimit') — not the Cache facade.
VALKEY_RATELIMIT_HOST=valkey_ratelimit
VALKEY_RATELIMIT_PORT=6379
VALKEY_RATELIMIT_PASSWORD=null

# Host ports for Valkey containers (Docker port mappings).
# Change these if 16379-16383 conflict with another process.
VALKEY_SESSIONS_HOST_PORT=16379
VALKEY_CACHE_HOST_PORT=16380
VALKEY_QUEUE_HOST_PORT=16381
VALKEY_AUCTION_HOST_PORT=16382
VALKEY_RATELIMIT_HOST_PORT=16383


# ────────────────────────────────────────────────────────────
# SESSION / CACHE / QUEUE DRIVERS
# ────────────────────────────────────────────────────────────

# Session storage backend. Must be 'redis' (connects to VALKEY_SESSIONS_*).
SESSION_DRIVER=redis

# Which Redis connection sessions use. Must be 'sessions'.
SESSION_CONNECTION=sessions

# Session lifetime in minutes. Default 120 (2 hours).
SESSION_LIFETIME=120

# Encrypt session data at rest. false in dev (avoids decryption overhead).
# true in production when handling sensitive data.
SESSION_ENCRYPT=false

SESSION_PATH=/
SESSION_DOMAIN=null

# Default cache store. Must be 'valkey'.
CACHE_STORE=valkey

# Queue connection. Must be 'valkey'.
QUEUE_CONNECTION=valkey

# Broadcasting (in-app messaging via Laravel Reverb).
# Use 'reverb' when Reverb is running; 'log' for dev without WebSockets.
BROADCAST_CONNECTION=log

# Default filesystem disk for general file operations.
FILESYSTEM_DISK=local


# ────────────────────────────────────────────────────────────
# MAIL
# ────────────────────────────────────────────────────────────

# Mail driver. Use 'smtp' for both dev (Mailpit) and production.
MAIL_MAILER=smtp

# In dev: 'mailpit' (Docker service name, port 1025) — all email captured locally.
# In production: your transactional email provider (Mailgun, Postmark, etc.).
MAIL_HOST=mailpit
MAIL_PORT=1025

# No auth needed for Mailpit.
MAIL_USERNAME=null
MAIL_PASSWORD=null

# Null = no TLS (Mailpit doesn't need it). Use 'tls' in production.
MAIL_SCHEME=null

# From address and name for all outgoing email.
MAIL_FROM_ADDRESS="noreply@americanheadhunter.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit web UI host port (for docker-compose.yml port mapping).
MAILPIT_PORT=8025


# ────────────────────────────────────────────────────────────
# STORAGE
#
# Two storage backends — one active at a time via FILESYSTEM_DISK.
# On-prem: Garage (S3-compatible, self-hosted).
# Azure: Azure Blob Storage.
# See docs/storage_strategy.md for migration path.
# ────────────────────────────────────────────────────────────

# Garage (on-prem S3-compatible storage)
# Used in dev and on-prem production.
GARAGE_ENDPOINT=
GARAGE_KEY_ID=
GARAGE_SECRET_KEY=
GARAGE_REGION=garage

# Bucket names for different content types:
GARAGE_BUCKET_PHOTOS=ah-photos
GARAGE_BUCKET_DOCUMENTS=ah-documents
GARAGE_BUCKET_VIDEOS=ah-videos
GARAGE_BUCKET_BACKUPS=ah-backups

# Azure Blob Storage
# Used in Azure production. Takes over from Garage after migration.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=

# Filament uploads go to this disk:
FILAMENT_FILESYSTEM_DISK=local


# ────────────────────────────────────────────────────────────
# STRIPE
# ────────────────────────────────────────────────────────────

# Public (publishable) key — safe to expose to browser via Vite.
STRIPE_KEY=

# Secret key — server-side only. Never expose to browser.
STRIPE_SECRET=

# Webhook signing secret — verifies that webhook payloads come from Stripe.
# Obtain from Stripe Dashboard → Webhooks → Signing secret.
STRIPE_WEBHOOK_SECRET=

# Stripe Connect client ID — for landowner connected account OAuth flow.
STRIPE_CONNECT_CLIENT_ID=


# ────────────────────────────────────────────────────────────
# DROPBOX SIGN (E-Signatures)
# ────────────────────────────────────────────────────────────

# API key for server-side Dropbox Sign API calls.
DROPBOX_SIGN_API_KEY=

# Client ID for embedded signing widget.
DROPBOX_SIGN_CLIENT_ID=

# Webhook signing secret — verifies callback payload authenticity.
DROPBOX_SIGN_WEBHOOK_SECRET=

# Set to true in local/staging so envelopes don't count against API quota.
DROPBOX_SIGN_TEST_MODE=true


# ────────────────────────────────────────────────────────────
# CLAMAV (Document Virus Scanning)
# ────────────────────────────────────────────────────────────

# When false (dev/test), uploaded documents are accepted without scanning.
# Enable in production and point host/port at a running clamd daemon.
CLAMAV_ENABLED=false

# clamd daemon host/port (e.g. CLAMAV_HOST=clamav for a docker-compose service).
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310

# Socket timeout in seconds for the scan.
CLAMAV_TIMEOUT=30


# ────────────────────────────────────────────────────────────
# MAPBOX
# ────────────────────────────────────────────────────────────

# Public token — safe to expose to browser. Used in Mapbox GL JS maps.
# Also passed to Vite as VITE_MAPBOX_TOKEN.
MAPBOX_PUBLIC_TOKEN=

# Secret token — server-side only. Used for server-side tile generation,
# geocoding, and Mapbox dataset management APIs.
MAPBOX_SECRET_TOKEN=


# ────────────────────────────────────────────────────────────
# CHECKR (Background Checks)
# ────────────────────────────────────────────────────────────

# API key for submitting background check requests.
CHECKR_API_KEY=

# Webhook secret — verifies callbacks from Checkr when results are ready.
CHECKR_WEBHOOK_SECRET=


# ────────────────────────────────────────────────────────────
# TAXJAR (Sales Tax)
# ────────────────────────────────────────────────────────────

# API key for TaxJar tax calculation.
TAXJAR_API_KEY=

# true = use TaxJar sandbox (no real tax calculations). false = production.
TAXJAR_SANDBOX=true


# ────────────────────────────────────────────────────────────
# TAX1099 (1099 Filing)
# ────────────────────────────────────────────────────────────

# API key for Tax1099 e-filing service.
TAX1099_API_KEY=

# true = sandbox mode (test filings, no real IRS submissions). false = production.
TAX1099_SANDBOX=true


# ────────────────────────────────────────────────────────────
# CLOUDFLARE
# ────────────────────────────────────────────────────────────

# Zone ID for the americanheadhunter.com domain — used for cache purge API calls.
CLOUDFLARE_ZONE_ID=

# API token with Cache Purge and Zone Read permissions.
CLOUDFLARE_API_TOKEN=


# ────────────────────────────────────────────────────────────
# AZURE KEY VAULT (Production encryption key source)
#
# In development, encryption keys come from ENCRYPTION_KEY_* env vars below.
# In production, DatabaseServiceProvider fetches keys from Azure Key Vault
# using these credentials. The Key Vault URL and identity are set by the
# Azure App Service managed identity or service principal.
# ────────────────────────────────────────────────────────────

# URL of the Azure Key Vault instance.
# Format: https://<vault-name>.vault.azure.net/
AZURE_KEY_VAULT_URL=

# Azure Active Directory tenant ID (production only).
AZURE_TENANT_ID=

# Service principal client ID (used if not using managed identity).
AZURE_CLIENT_ID=

# Service principal client secret (used if not using managed identity).
# In production, prefer managed identity over client secret.
AZURE_CLIENT_SECRET=


# ────────────────────────────────────────────────────────────
# PER-DATABASE ENCRYPTION KEYS
#
# These keys are used by pgp_sym_encrypt / pgp_sym_decrypt for fields
# marked '-- encrypted' in the schema docs.
#
# Only four databases have encrypted columns:
#   identity  — phone numbers, SSN fragments
#   billing   — W-9 TIN data
#   lease     — gate codes, WiFi passwords, cabin codes
#   documents — sensitive document metadata
#
# In PRODUCTION: these values come from Azure Key Vault.
#   DatabaseServiceProvider fetches them at boot.
#   Never set these in production .env files.
#
# In DEVELOPMENT: set these to any 32-byte string.
#   Use different values for each DB — key reuse is a security risk.
#
# Rules:
#   - Minimum 16 bytes, 32 recommended.
#   - Never log these values, even in debug mode.
#   - Never log a decrypted field value.
#   - Rotation requires re-encrypting all affected rows.
# ────────────────────────────────────────────────────────────

ENCRYPTION_KEY_IDENTITY=
ENCRYPTION_KEY_BILLING=
ENCRYPTION_KEY_LEASE=
ENCRYPTION_KEY_DOCUMENTS=


# ────────────────────────────────────────────────────────────
# VITE (Frontend build)
# ────────────────────────────────────────────────────────────

# Variables prefixed VITE_ are exposed to the browser via Vite.
# Only include values that are safe to be public.

# App name for use in React components.
VITE_APP_NAME="${APP_NAME}"

# Mapbox public token — used by Mapbox GL JS in the browser.
# References MAPBOX_PUBLIC_TOKEN above — no duplicate value needed.
VITE_MAPBOX_TOKEN="${MAPBOX_PUBLIC_TOKEN}"
