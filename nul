}
body.fi-body:not(:has(.fi-simple-layout)) {
    background-color: #f4ecdc !important;
}

/* ============================================================
   ADMIN MAIN LAYOUT — Parchment / Ink Theme
   ============================================================ */

/* ── Topbar ─────────────────────────────────────────────────── */
